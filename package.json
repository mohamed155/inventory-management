{
  "name": "inventory-management",
  "description": "A simple inventory management app",
  "author": "Mohamed Ramadan",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "main": "dist-electron/electron.js",
  "scripts": {
    "dev": "concurrently --kill-others \"bun run dev-react\" \"bun run dev-electron\"",
    "dev-react": "bunx --bun vite",
    "dev-electron": "wait-on http:localhost:5173 && cross-env ELECTRON_START_URL=http:localhost:5173 bunx --bun electron ./src/electron.ts",
    "build": "bun run db:generate && tsc -b && vite build && bunx esbuild src/electron.ts src/preload.ts --bundle --packages=external --platform=node --target=node22 --format=esm --outdir=dist-electron",
    "package": "bun run build && bunx electron-builder",
    "publish": "bun run build && dotenv -e .env.local -- bunx electron-builder --publish always",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:generate": "bunx --bun prisma generate",
    "db:push": "bunx --bun prisma db push",
    "db:pull": "bunx --bun prisma db pull"
  },
  "build": {
    "appId": "com.mohamed155.inventorymanagement",
    "productName": "Inventory Management",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "prisma/migrations/**/*",
      "!node_modules/@prisma/engines/**/*",
      "!node_modules/@prisma/studio-core/**/*",
      "!node_modules/@prisma/dev/**/*",
      "!node_modules/@prisma/fetch-engine/**/*",
      "!node_modules/**/*.md",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/test/**/*",
      "!node_modules/**/tests/**/*",
      "!node_modules/**/__tests__/**/*",
      "!node_modules/**/prebuilds/linux*/**/*",
      "!node_modules/**/prebuilds/darwin*/**/*",
      "!node_modules/**/prebuilds/android*/**/*",
      "!node_modules/**/*-linux-*",
      "!node_modules/**/*-darwin-*",
      "!node_modules/**/*-android-*",
      "!node_modules/**/linux/**/*",
      "!node_modules/**/darwin/**/*"
    ],
    "electronLanguages": [
      "en-US"
    ],
    "directories": {
      "buildResources": "src/assets"
    },
    "extraResources": [
      {
        "from": "src/splash.html",
        "to": "splash.html"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "mohamed155",
      "repo": "inventory-management"
    }
  },
  "dependencies": {
    "@prisma/adapter-libsql": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@sentry/electron": "^7.11.0",
    "bcryptjs": "^3.0.3",
    "electron-updater": "^6.8.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@eslint/js": "^10.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/react": "^10.50.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-table": "^8.21.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "dotenv-cli": "^11.0.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.9.0",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "i18next": "^26.0.8",
    "lucide-react": "^1.11.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "prisma": "^7.8.0",
    "puppeteer": "^24.42.0",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-i18next": "^17.0.4",
    "react-router": "^7.14.2",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
